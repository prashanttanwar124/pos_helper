{
  "name": "nfc-helper-bridge",
  "version": "1.0.0",
  "description": "Local desktop NFC helper for ACR122U using Node.js, nfc-pcsc, and Express",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node index.js",
    "helper:start": "node index.js",
    "helper:rebuild-native": "node scripts/rebuild-helper-native.js",
    "desktop:dev": "npm run helper:rebuild-native && npm run desktop:prepare-runtime && electron .",
    "desktop:prepare-runtime": "node scripts/prepare-desktop-runtime.js",
    "desktop:build": "npm run helper:rebuild-native && npm run desktop:prepare-runtime && electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "nfc-pcsc": "^0.8.1"
  },
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.maniratn.nfchelper.desktop",
    "productName": "NFC Helper Control",
    "icon": "build/icon.ico",
    "files": [
      "desktop/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".desktop-runtime/runtime",
        "to": "runtime"
      },
      {
        "from": ".desktop-runtime/helper",
        "to": "helper"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
